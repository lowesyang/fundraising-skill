#!/bin/bash
# fundraising-skill update checker
# Compares local VERSION against remote VERSION on GitHub
# Returns: UPGRADE_AVAILABLE <old> <new> | JUST_UPGRADED <old> <new> | (nothing)

set -e

REPO_RAW="https://raw.githubusercontent.com/lowesyang/fundraising-skill/main/VERSION"
STATE_DIR="$HOME/.fundraising-skill"
CACHE_FILE="$STATE_DIR/last-update-check"
UPGRADED_FILE="$STATE_DIR/just-upgraded-from"
CACHE_TTL_MINUTES=30
CONFIG_FILE="$STATE_DIR/config"
SKIP_FILE="$STATE_DIR/skip-session"

# Find install directory (where this script lives)
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOCAL_VERSION_FILE="$SCRIPT_DIR/VERSION"

# Ensure state directory exists
mkdir -p "$STATE_DIR"

# Check if user skipped this session (skip file younger than 4 hours)
if [ -f "$SKIP_FILE" ]; then
    SKIP_AGE=$(( ($(date +%s) - $(stat -f %m "$SKIP_FILE" 2>/dev/null || stat -c %Y "$SKIP_FILE" 2>/dev/null || echo 0)) / 3600 ))
    if [ "$SKIP_AGE" -lt 4 ]; then
        exit 0  # User said "skip this time"
    fi
fi

# Check for just-upgraded marker
if [ -f "$UPGRADED_FILE" ]; then
    OLD_VER=$(cat "$UPGRADED_FILE")
    NEW_VER=$(cat "$LOCAL_VERSION_FILE" 2>/dev/null | tr -d '[:space:]')
    echo "JUST_UPGRADED $OLD_VER $NEW_VER"
    rm -f "$UPGRADED_FILE"
    exit 0
fi

# Read local version
LOCAL_VER=$(cat "$LOCAL_VERSION_FILE" 2>/dev/null | tr -d '[:space:]')
if [ -z "$LOCAL_VER" ]; then
    exit 0  # No VERSION file, skip silently
fi

# Check cache. Cache is invalidated if:
#   1. It's older than CACHE_TTL_MINUTES
#   2. The local version has changed since the cache was written (user upgraded)
# Cache format: first line = local version at write time, second line = result
if [ -f "$CACHE_FILE" ]; then
    CACHE_AGE=$(( ($(date +%s) - $(stat -f %m "$CACHE_FILE" 2>/dev/null || stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0)) / 60 ))
    CACHE_LOCAL_VER=$(sed -n '1p' "$CACHE_FILE" 2>/dev/null)
    CACHED_RESULT=$(sed -n '2p' "$CACHE_FILE" 2>/dev/null)

    # Backwards compat: old cache files are single-line and have no version fingerprint.
    # Treat them as stale so they get rewritten in the new format.
    if [ -z "$CACHED_RESULT" ] || [ -z "$CACHE_LOCAL_VER" ]; then
        rm -f "$CACHE_FILE"
    elif [ "$CACHE_AGE" -lt "$CACHE_TTL_MINUTES" ] && [ "$CACHE_LOCAL_VER" = "$LOCAL_VER" ]; then
        if [ "$CACHED_RESULT" != "UP_TO_DATE" ]; then
            echo "$CACHED_RESULT"
        fi
        exit 0
    fi
fi

# Fetch remote version (timeout 5s, fail silently)
REMOTE_VER=$(curl -sL --max-time 5 "$REPO_RAW" 2>/dev/null | tr -d '[:space:]')
if [ -z "$REMOTE_VER" ]; then
    exit 0  # Network error, skip silently
fi

# Compare versions
if [ "$LOCAL_VER" = "$REMOTE_VER" ]; then
    printf '%s\nUP_TO_DATE\n' "$LOCAL_VER" > "$CACHE_FILE"
    exit 0
fi

# Simple version comparison (works for semver without pre-release)
LOCAL_PARTS=$(echo "$LOCAL_VER" | tr '.' ' ')
REMOTE_PARTS=$(echo "$REMOTE_VER" | tr '.' ' ')

NEEDS_UPGRADE=false
set -- $LOCAL_PARTS
L1=${1:-0}; L2=${2:-0}; L3=${3:-0}
set -- $REMOTE_PARTS
R1=${1:-0}; R2=${2:-0}; R3=${3:-0}

if [ "$R1" -gt "$L1" ] 2>/dev/null; then
    NEEDS_UPGRADE=true
elif [ "$R1" -eq "$L1" ] && [ "$R2" -gt "$L2" ] 2>/dev/null; then
    NEEDS_UPGRADE=true
elif [ "$R1" -eq "$L1" ] && [ "$R2" -eq "$L2" ] && [ "$R3" -gt "$L3" ] 2>/dev/null; then
    NEEDS_UPGRADE=true
fi

if [ "$NEEDS_UPGRADE" = true ]; then
    # Check if auto_upgrade is enabled
    AUTO="false"
    if [ -f "$CONFIG_FILE" ] && grep -q "auto_upgrade=true" "$CONFIG_FILE" 2>/dev/null; then
        AUTO="true"
    fi

    if [ "$AUTO" = "true" ]; then
        RESULT="AUTO_UPGRADE $LOCAL_VER $REMOTE_VER"
    else
        RESULT="UPGRADE_AVAILABLE $LOCAL_VER $REMOTE_VER"
    fi
    printf '%s\n%s\n' "$LOCAL_VER" "$RESULT" > "$CACHE_FILE"
    echo "$RESULT"
else
    printf '%s\nUP_TO_DATE\n' "$LOCAL_VER" > "$CACHE_FILE"
fi
